---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?><feed xmlns="http://www.w3.org/2005/Atom" ><generator uri="https://www.11ty.dev/" version="3.0.0">Eleventy</generator><link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/atom+xml" /><link href="{{ site.url }}{{ site.baseurl }}/" rel="alternate" type="text/html" /><updated>{{ collections.posts | getNewestCollectionItemDate | dateToRfc3339 }}</updated><id>{{ site.url }}{{ site.baseurl }}/feed.xml</id><title type="html">{{ site.title }}</title><subtitle>{{ site.description }}</subtitle>
{%- set feedPosts = collections.posts | reverse | head(15) %}
{%- for post in feedPosts %}
{%- set postAbsoluteUrl = post.url | htmlBaseUrl(site.url + site.baseurl) %}
{%- set postIdUrl = postAbsoluteUrl | stripHtmlExtension %}
<entry><title type="html">{{ post.data.title }}</title><link href="{{ postAbsoluteUrl }}" rel="alternate" type="text/html" title="{{ post.data.title }}" /><published>{{ post.date | dateToRfc3339 }}</published><updated>{{ post.date | dateToRfc3339 }}</updated><id>{{ postIdUrl }}</id><content type="html" xml:base="{{ postAbsoluteUrl }}"><![CDATA[{{ post.templateContent | renderTransforms(post.data.page, site.url + site.baseurl) | safe }}]]></content><author><name></name></author>
{%- for tag in post.data.tags %}{%- if tag != "posts" %}<category term="{{ tag }}" />{% endif %}{%- endfor %}
{%- if post.data.description %}<summary type="html"><![CDATA[{{ post.data.description }}]]></summary>{% endif %}</entry>
{%- endfor %}
</feed>
