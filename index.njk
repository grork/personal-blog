---
permalink: /
---
<!doctype html>
<html prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link type="application/atom+xml" rel="alternate" href="{{ '/feed.xml' | url }}" title="{{ site.title }}">
    {% include "seo.njk" %}
    <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
    <title>{{ site.title }}</title>
  </head>
  <body>
    <!-- Site Header -->
    <header>
      <h1>{{ site.title }}</h1>
    </header>
    <!-- Grouped by Year -->
    {% set postsByYear = collections.posts | reverse | groupByYear %}
    <main>
    {% for year in postsByYear %}
      <!-- Individual year -->
      <div class="group-container">
        <div class="group-display">{{ year.name }}</div>
        <!-- Posts in that year -->
        <div class="group-posts">
          {% for post in year.items %}
            {% include "individual_post.njk" %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
    </main>
    {% include "footer.njk" %}
  </body>
</html>
